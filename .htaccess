# Thrive
DirectoryIndex index.php
Options -Indexes

# Defense-in-depth: never serve source, VCS, build or config files.
# (The clean setup is to check the git repo out OUTSIDE the web root.)
RedirectMatch 404 ^/(\.git|capacitor-app|android-app|node_modules|includes)(/|$)
<FilesMatch "^(\.cpanel\.yml|\.gitignore|\.gitattributes|README\.md|HEALTHCONNECT\.md|package(-lock)?\.json)$">
  Require all denied
</FilesMatch>

# Use PHP 8.3 (cPanel/EasyApache handler). If your host offers a different
# 8.x version, change ea-php83 to ea-php82 / ea-php81 accordingly.
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php83 .php .phtml
  # Serve the Android app with the correct type so browsers download it.
  AddType application/vnd.android.package-archive .apk
</IfModule>

<IfModule mod_headers.c>
  Header set X-Frame-Options "SAMEORIGIN"
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  # 180-day HSTS (site is HTTPS-only via Cloudflare)
  Header always set Strict-Transport-Security "max-age=15552000"
  # Don't let Cloudflare/browsers cache the APK — otherwise a new build keeps
  # serving the old cached file. (The download link is also cache-busted.)
  <FilesMatch "\.apk$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>
